# fall-guard-cv 環境設定範本(複製為 .env 後填入真值;.env 已在 .gitignore)

# === 金鑰 ===
GOOGLE_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=
WANDB_API_KEY=
# Discord 頻道設定 → 整合 → Webhook → 複製 URL
DISCORD_WEBHOOK_URL=

# === 模型字串(程式不寫死,一律由此設定;預設值見 CLAUDE.md 模型政策) ===
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
OPENAI_MODEL=gpt-5-mini
POSE_MODEL=yolo26m-pose.pt

# === 偵測與通報參數 ===
# 倒地持續幾秒才通報(評估腳本固定用 2;實際部署建議 10,見 docs/PLAN.md D11)
FALL_CONFIRM_SECONDS=10
# 通報後冷卻幾秒(期間不重複通報)
ALERT_COOLDOWN_SECONDS=120
# true = 完全離線模式:跳過 VLM,截圖僅存本機,Discord 只發文字
LOCAL_ONLY=false
# false = Discord 通報不附截圖(只發文字+特徵摘要)
SEND_IMAGE=true
